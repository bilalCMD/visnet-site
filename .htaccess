# ============================================================
# VIS Networks — clean URLs for Apache hosting (GoDaddy/cPanel)
# Serves /about instead of /about.html automatically.
# ============================================================
RewriteEngine On

# 1) If someone visits the old .html URL, redirect to the clean URL
RewriteCond %{THE_REQUEST} \s/+([^?\s]+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 2) Internally serve the .html file for the clean URL
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

ErrorDocument 404 /index.html
